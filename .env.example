# agent-skills — secrets contract
#
# Skills read API keys from environment variables, never from the skill file.
# Copy the lines you need into your real env file, kept OUTSIDE this repo:
#
#     ~/.config/agent-skills/.env   (chmod 600)
#
# Then fill in each value. Variable names are fixed; do not rename them.
# This example file is committed and must never contain a real key.

# image-gateway — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# current-info-search — Perplexity (https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=

# media-transcription — AssemblyAI (https://www.assemblyai.com/app/account)
ASSEMBLYAI_API_KEY=
